---
import nav from '../data/navigation.json';
import { url } from '../utils/url';

const { mainNav, ctaNav } = nav;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo + claim -->
      <a href={url('/')} class="flex-shrink-0">
        <img src={url('/images/logo-claim.svg')} alt="Recèto — Faire de bonnes recettes" class="h-10 lg:h-12 w-auto" />
      </a>

      <!-- Desktop nav + CTA -->
      <div class="hidden md:flex items-center gap-8">
        <nav class="flex items-center">
          {mainNav.map((item, i) => (
            <>
              <a href={url(item.href)} class="text-base font-body text-gray-900 hover:text-brand-500 transition-colors">
                {item.label}
              </a>
              {i < mainNav.length - 1 && (
                <span class="mx-4 h-4 w-px bg-gray-300" aria-hidden="true"></span>
              )}
            </>
          ))}
        </nav>
        <a
          href={url(ctaNav.secondary.href)}
          class="inline-flex items-center justify-center rounded-xl border border-gray-900 px-5 py-2.5 text-base font-medium text-gray-900 hover:bg-gray-900 hover:text-white transition-colors"
        >
          {ctaNav.secondary.label}
        </a>
        <a
          href={url(ctaNav.primary.href)}
          class="inline-flex items-center justify-center rounded-xl bg-brand-500 px-5 py-2.5 text-base font-semibold text-white hover:bg-brand-600 transition-colors"
        >
          {ctaNav.primary.label}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-gray-600 hover:text-gray-900"
        aria-expanded="false"
        aria-label="Menu principal"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-4 space-y-3">
      {mainNav.map((item) => (
        <a href={url(item.href)} class="block text-base font-medium text-gray-600 hover:text-brand-500">
          {item.label}
        </a>
      ))}
      <hr class="border-gray-100" />
      <a
        href={url(ctaNav.secondary.href)}
        class="block w-full text-center rounded-xl border border-gray-900 px-4 py-2.5 text-base font-medium text-gray-900 hover:bg-gray-900 hover:text-white"
      >
        {ctaNav.secondary.label}
      </a>
      <a
        href={url(ctaNav.primary.href)}
        class="block w-full text-center rounded-xl bg-brand-500 px-4 py-2.5 text-base font-semibold text-white hover:bg-brand-600"
      >
        {ctaNav.primary.label}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    menuIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
