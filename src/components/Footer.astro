---
import nav from '../data/navigation.json';
import { url } from '../utils/url';
import contact from '../data/contact.json';

const { footerNav } = nav;
---

<footer class="bg-gray-50 border-t border-gray-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12">
      <!-- Gauche -->
      <div class="space-y-10">
        <!-- Slogan -->
        <div>
          <h3 class="font-heading text-4xl sm:text-5xl text-gray-950 leading-tight tracking-wide">
            Recèto<br/>Faire de bonnes recettes
          </h3>
        </div>

        <!-- Suivez-nous -->
        <div>
          <p class="font-heading text-3xl text-gray-950 tracking-wide mb-4">Suivez-nous</p>
          <div class="flex flex-wrap items-center gap-6 sm:gap-8">
            <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-900 hover:text-brand-500 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href={contact.instagram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-gray-900 hover:text-brand-500 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              Instagram
            </a>
          </div>
        </div>

        <!-- Liens footer -->
        <div class="grid grid-cols-2 gap-x-16 gap-y-3">
          <div class="space-y-3">
            {footerNav.legal.map((item) => (
              <a href={url(item.href)} class="block text-xs text-gray-900 hover:text-brand-500 transition-colors">
                {item.label}
              </a>
            ))}
            <a href={url('/faq')} class="block text-xs text-gray-900 hover:text-brand-500 transition-colors">FAQ</a>
          </div>
          <div class="space-y-3">
            {footerNav.company.map((item) => (
              <a href={url(item.href)} class="block text-xs text-gray-900 hover:text-brand-500 transition-colors">
                {item.label}
              </a>
            ))}
            <a href={`mailto:${contact.email}`} class="block text-xs text-gray-900 hover:text-brand-500 transition-colors">Contact</a>
          </div>
        </div>
      </div>

      <!-- Droite — Carte inscription -->
      <div class="bg-brand-500 rounded-2xl p-8 sm:p-10 w-full lg:w-96 text-white">
        <p class="font-heading text-3xl sm:text-4xl tracking-wide">Inscription</p>
        <p class="mt-2 text-xs opacity-90">Tu veux être alerté du lancement officiel ?</p>
        <form class="mt-6" action="https://formspree.io/f/mdawabeg" method="POST">
          <input type="hidden" name="_subject" value="Nouvelle inscription newsletter Recèto" />
          <input type="hidden" name="_replyto" id="footer-replyto" />
          <label for="footer-email" class="block text-[10px] text-brand-200 mb-1">Email</label>
          <input
            type="email"
            id="footer-email"
            name="email"
            required
            class="w-full rounded-md border border-white/30 bg-white px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:outline-none focus:ring-2 focus:ring-white"
            placeholder="votre@email.fr"
          />
          <button
            type="submit"
            class="mt-4 w-full rounded-lg bg-white text-brand-500 font-semibold py-2.5 text-sm hover:bg-brand-50 transition-colors"
          >
            Envoyez !
          </button>
        </form>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-6 border-t border-gray-200">
      <p class="text-[8px] text-gray-500">&copy; {new Date().getFullYear()} SAS ECO2Chef</p>
    </div>
  </div>
</footer>
