---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
---

<BaseLayout
  title="Page introuvable"
  description="Cette page n'existe pas ou a été déplacée."
  noindex={true}
>
  <section class="relative py-28 lg:py-40 overflow-hidden">
    <img
      src={url('/images/wave-blue.png')}
      alt=""
      class="absolute right-0 top-0 h-full w-auto object-cover pointer-events-none opacity-20"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-2xl px-4 text-center">
      <p class="font-heading text-8xl sm:text-9xl text-brand-500">404</p>
      <h1 class="mt-6 font-heading text-4xl sm:text-5xl text-gray-950">Page introuvable</h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        Cette page n'existe pas ou a été déplacée. Pas de panique, votre prochaine recette rentable vous attend.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={url('/')}
          class="inline-flex items-center justify-center rounded-[10px] bg-brand-500 px-6 py-3.5 text-base font-semibold text-white hover:bg-brand-600 transition-colors"
        >
          Retour à l'accueil
        </a>
        <a
          href={url('/demo')}
          class="inline-flex items-center justify-center rounded-[10px] border-2 border-gray-950 px-6 py-3.5 text-base font-semibold text-gray-950 hover:border-brand-500 hover:text-brand-500 transition-colors"
        >
          Demander une démo
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
