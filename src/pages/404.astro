---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
---

<BaseLayout
  title="Page introuvable"
  description="Cette page n'existe pas ou a été déplacée."
  noindex={true}
>
  <section class="flex flex-col items-center justify-center min-h-[calc(100vh-160px)] px-4 text-center gap-8">
    <p class="font-heading text-8xl sm:text-9xl xl:text-[128px] xl:leading-[120px] text-brand-600">404</p>
    <h1 class="font-lexend font-medium text-2xl sm:text-[30px] sm:leading-[36px] text-gray-950">
      Quelqu'un a mangé la recette.
    </h1>
    <p class="font-lexend text-lg sm:text-2xl sm:leading-[30px] text-gray-950 max-w-2xl">
      La page que vous cherchez a peut-être changé d'ingrédient…<br />
      ou disparu du menu.
    </p>
    <a
      href={url('/')}
      class="inline-flex items-center justify-center rounded-[5px] border border-brand-500 px-8 py-3 font-lexend text-base text-brand-600 hover:bg-brand-500 hover:text-white transition-colors"
    >
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
