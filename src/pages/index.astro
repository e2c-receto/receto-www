---
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqItems } from '../data/faq';
import { ctaNav } from '../data/navigation';
import { url } from '../utils/url';
---

<BaseLayout
  title="Accueil"
  description="Recèto : l'application qui calcule la marge ET l'empreinte carbone de vos recettes. Pour les chefs qui veulent des recettes rentables et durables."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Texte -->
        <div>
          <h1 class="text-4xl sm:text-5xl xl:text-6xl leading-tight tracking-tight text-gray-950">
            Chefs de cuisine, augmentez votre marge et réduisez votre impact CO2&nbsp;!
          </h1>
          <p class="mt-6 text-xl sm:text-2xl font-medium text-gray-950 max-w-xl">
            Recèto&nbsp;: L'outil de pilotage des Chefs qui rend les recettes rentables et éco-responsables.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a
              href={ctaNav.primary.href}
              class="inline-flex items-center justify-center rounded-xl bg-brand-500 px-6 py-3 text-base font-semibold text-white hover:bg-brand-600 transition-colors shadow-lg shadow-brand-500/25"
            >
              Essayer gratuitement
            </a>
            <a
              href={ctaNav.secondary.href}
              class="inline-flex items-center justify-center rounded-xl border border-gray-300 px-6 py-3 text-base font-semibold text-gray-700 hover:border-brand-500 hover:text-brand-500 transition-colors"
            >
              Demander une démo
            </a>
          </div>
        </div>
        <!-- Mockup iPhone -->
        <div class="relative flex justify-center lg:justify-end">
          <img
            src={url('/images/mockup-iphone.png')}
            alt="Application Recèto sur iPhone"
            class="w-64 sm:w-72 lg:w-80 xl:w-96 h-auto drop-shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features — fond bleu -->
  <section class="relative bg-brand-500 py-20 lg:py-28 overflow-hidden">
    <!-- Vague décorative multicolore -->
    <img
      src={url('/images/wave-blue.png')}
      alt=""
      class="absolute right-0 top-0 h-full w-auto object-cover pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Rentabilité -->
        <div class="bg-white rounded-2xl p-8 text-center">
          <div class="mx-auto w-20 h-20 rounded-full bg-white flex items-center justify-center mb-6 shadow-sm">
            <img src={url('/images/icons/feature-rentabilite.svg')} alt="" class="w-10 h-10" />
          </div>
          <h3 class="text-2xl font-bold text-gray-950 mb-4">Rentabilité Assurée</h3>
          <p class="text-gray-600 leading-relaxed">
            Optimisez vos recettes pour maximiser vos marges et garantir la rentabilité de chaque plat, grâce à une analyse précise des coûts et des ingrédients.
          </p>
        </div>
        <!-- Impact CO2 -->
        <div class="bg-white rounded-2xl p-8 text-center">
          <div class="mx-auto w-20 h-20 rounded-full bg-white flex items-center justify-center mb-6 shadow-sm">
            <img src={url('/images/icons/feature-co2.svg')} alt="" class="w-10 h-10" />
          </div>
          <h3 class="text-2xl font-bold text-gray-950 mb-4">Impact CO2</h3>
          <p class="text-gray-600 leading-relaxed">
            Diminuez l'empreinte carbone de vos recettes en identifiant rapidement les leviers d'amélioration et en choisissant les options les plus responsables.
          </p>
        </div>
        <!-- Gestion simplifiée -->
        <div class="bg-white rounded-2xl p-8 text-center">
          <div class="mx-auto w-20 h-20 rounded-full bg-white flex items-center justify-center mb-6 shadow-sm">
            <img src={url('/images/icons/feature-gestion.svg')} alt="" class="w-10 h-10" />
          </div>
          <h3 class="text-2xl font-bold text-gray-950 mb-4">Gestion Simplifiée</h3>
          <p class="text-gray-600 leading-relaxed">
            Gérez facilement vos ingrédients, fournisseurs et calculs automatiques&nbsp;: tout est centralisé et actualisé en temps réel pour un pilotage sans stress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comment ça marche ? -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Texte -->
        <div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl text-gray-950">Comment ça marche&nbsp;?</h2>
          <p class="mt-4 text-xl sm:text-2xl font-medium text-gray-950">
            Optimisez vos coûts matière en 3 clics&nbsp;!
          </p>
          <div class="mt-10 space-y-6">
            <!-- Étape 1 -->
            <div class="flex items-center gap-4">
              <div class="flex-shrink-0 w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center">
                <img src={url('/images/icons/step-fournisseurs.svg')} alt="" class="w-7 h-7" />
              </div>
              <p class="text-lg text-gray-900">Entrez vos fournisseurs &amp; produits</p>
            </div>
            <!-- Étape 2 -->
            <div class="flex items-center gap-4">
              <div class="flex-shrink-0 w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center">
                <img src={url('/images/icons/step-recette.svg')} alt="" class="w-7 h-7" />
              </div>
              <p class="text-lg text-gray-900">Ajoutez votre recette</p>
            </div>
            <!-- Étape 3 -->
            <div class="flex items-center gap-4">
              <div class="flex-shrink-0 w-14 h-14 rounded-full bg-gray-50 flex items-center justify-center">
                <img src={url('/images/icons/step-rentabilite.svg')} alt="" class="w-7 h-7" />
              </div>
              <p class="text-lg text-gray-900">Ajustez pour la rentabilité</p>
            </div>
          </div>
        </div>
        <!-- Screenshot app (forme libre avec contour propre, pas de box) -->
        <div class="flex justify-center lg:justify-end">
          <img
            src={url('/images/app-screenshot.png')}
            alt="Capture d'écran de l'application Recèto — Bien plus qu'un food cost"
            class="w-full max-w-sm lg:max-w-md h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Notre service — fond bleu -->
  <section class="bg-brand-500 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <!-- Texte -->
        <div class="text-white">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl">Notre service</h2>
          <p class="mt-4 text-xl sm:text-2xl font-medium">
            Adoptez Recèto avec ou sans engagement
          </p>
          <div class="mt-8 space-y-8 text-lg leading-relaxed opacity-90">
            <p>
              Gérez facilement vos ingrédients, fournisseurs et calculs automatiques&nbsp;: tout est centralisé et actualisé en temps réel pour un pilotage sans stress.
            </p>
            <p>
              Rejoignez dès aujourd'hui une communauté engagée et boostez la gestion de vos fiches techniques&nbsp;: l'inscription est gratuite, sans engagement, et la prise en main rapide. Passez à la cuisine éco-responsable et rentable&nbsp;!
            </p>
            <p>
              Avec Recèto, profitez d'une solution clé en main pour optimiser vos recettes, réduire vos coûts et agir concrètement pour l'environnement.
            </p>
          </div>
        </div>
        <!-- Carte pricing simplifiée -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-xl">
          <div class="bg-brand-600 py-5 text-center">
            <p class="text-xl font-body text-white">OFFRE DÉCOUVERTE GRATUITE</p>
          </div>
          <div class="p-8 text-center">
            <div class="flex items-baseline justify-center">
              <span class="text-7xl font-heading font-black text-gray-950">39</span>
              <span class="text-3xl font-bold text-gray-950 ml-1">€</span>
            </div>
            <p class="mt-2 text-gray-600">Par mois HT, dès l'offre Essentiel</p>
            <ul class="mt-6 space-y-3 text-sm text-gray-700">
              <li class="flex items-center justify-center gap-2">
                <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Jusqu'à 25 recettes et 10 fournisseurs
              </li>
              <li class="flex items-center justify-center gap-2">
                <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Empreinte carbone de chaque recette
              </li>
              <li class="flex items-center justify-center gap-2">
                <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Scan de factures et export PDF
              </li>
            </ul>
            <a
              href={url('/tarifs')}
              class="mt-8 inline-flex items-center justify-center w-full rounded-lg bg-brand-500 py-3 text-base font-semibold text-white hover:bg-brand-600 transition-colors"
            >
              Voir tous les tarifs
            </a>
            <p class="mt-4 text-xs text-gray-500 leading-relaxed">
              Sans engagement, sans revente de données. Hébergement France / UE.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ils nous font confiance -->
  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl text-gray-950 text-center mb-12">Ils nous font confiance</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 items-center justify-items-center">
        <img src={url('/images/partners/talenz.png')} alt="Talenz" class="h-24 w-auto object-contain grayscale hover:grayscale-0 transition-all" loading="lazy" />
        <img src={url('/images/partners/cci.png')} alt="CCI Vaucluse" class="h-24 w-auto object-contain grayscale hover:grayscale-0 transition-all" loading="lazy" />
        <img src={url('/images/partners/grand-avignon.png')} alt="Grand Avignon" class="h-24 w-auto object-contain grayscale hover:grayscale-0 transition-all" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 lg:py-24 bg-gray-50">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl text-gray-950 text-center mb-12">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqItems.map((item, i) => (
          <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden" open={i === 0}>
            <summary class="flex cursor-pointer items-center justify-between p-5 font-medium text-gray-950 hover:bg-gray-50 transition-colors">
              {item.question}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-gray-600 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        }
      }))
    })} />
  </section>

  <!-- CTA final -->
  <section class="bg-brand-500 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="text-3xl sm:text-4xl text-white">Prêt à créer des recettes rentables&nbsp;?</h2>
      <p class="mt-4 text-lg text-brand-100">
        Rejoignez les restaurateurs qui maîtrisent leurs marges et leur impact.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={ctaNav.primary.href} class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-base font-semibold text-brand-500 hover:bg-brand-50 transition-colors">
          {ctaNav.primary.label}
        </a>
        <a href={ctaNav.secondary.href} class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl border border-white/30 px-6 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors">
          {ctaNav.secondary.label}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
