---
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqItems } from '../data/faq';
import { plans } from '../data/pricing';
import { ctaNav } from '../data/navigation';
import { url } from '../utils/url';
---

<BaseLayout
  title="Accueil"
  description="Recèto : l'application qui calcule la marge ET l'empreinte carbone de vos recettes. Pour les chefs qui veulent des recettes rentables et durables."
>
  <!-- Hero — fond blanc -->
  <section class="overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Texte -->
        <div class="text-gray-950">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-[6.5rem] leading-[0.95]">
            Chefs de cuisine, augmentez votre marge et réduisez votre impact CO2&nbsp;!
          </h1>
          <p class="mt-8 text-xl sm:text-2xl lg:text-[1.875rem] lg:leading-9 font-medium max-w-2xl">
            Recèto&nbsp;: L'outil de pilotage des Chefs qui rend les recettes rentables et éco-responsables.
          </p>
          <p class="mt-6 text-lg sm:text-xl lg:text-2xl text-gray-700">
            Je calcule une recette type&nbsp;!
          </p>
          <div class="mt-8">
            <a
              href={ctaNav.secondary.href}
              class="inline-flex items-center justify-center rounded-[10px] bg-brand-500 px-5 py-3.5 text-lg sm:text-xl font-semibold text-white hover:bg-brand-600 transition-colors"
            >
              Demander une démo
            </a>
          </div>
        </div>
        <!-- Mockup App -->
        <div class="relative flex justify-center lg:justify-end">
          <img
            src={url('/images/mockup-recette-detail.png')}
            alt="Application Recèto — détail recette"
            class="w-56 sm:w-64 lg:w-72 xl:w-[20rem] h-auto drop-shadow-2xl rounded-[20px]"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features — fond bleu -->
  <section class="relative bg-brand-500 overflow-hidden">
    <img
      src={url('/images/wave-blue.png')}
      alt=""
      class="absolute right-0 top-0 h-full w-auto object-cover pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6 lg:px-12 py-20 lg:py-28">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-[60px] justify-items-center">
        <!-- Rentabilité -->
        <div class="bg-white rounded-[20px] p-8 text-center w-full max-w-[360px] aspect-square flex flex-col items-center justify-start pt-8">
          <div class="w-20 h-20 rounded-full bg-white flex items-center justify-center mb-2">
            <img src={url('/images/icons/feature-rentabilite.svg')} alt="" class="w-10 h-10" />
          </div>
          <h3 class="text-3xl sm:text-4xl lg:text-[4rem] lg:leading-[5rem] text-gray-950 mb-5">Rentabilité assurée</h3>
          <p class="text-gray-700 text-base lg:text-[1.1rem] lg:leading-7">
            Optimisez vos recettes pour maximiser vos marges et garantir la rentabilité de chaque plat, grâce à une analyse précise des coûts et des ingrédients.
          </p>
        </div>
        <!-- Impact CO2 -->
        <div class="bg-white rounded-[20px] p-8 text-center w-full max-w-[360px] aspect-square flex flex-col items-center justify-start pt-8">
          <div class="w-20 h-20 rounded-full bg-white flex items-center justify-center mb-2">
            <img src={url('/images/icons/feature-co2.svg')} alt="" class="w-10 h-10" />
          </div>
          <h3 class="text-3xl sm:text-4xl lg:text-[4rem] lg:leading-[5rem] text-gray-950 mb-5">Impact CO2</h3>
          <p class="text-gray-700 text-base lg:text-[1.1rem] lg:leading-7">
            Diminuez l'empreinte carbone de vos recettes en identifiant rapidement les leviers d'amélioration et en choisissant les options les plus responsables.
          </p>
        </div>
        <!-- Gestion simplifiée -->
        <div class="bg-white rounded-[20px] p-8 text-center w-full max-w-[360px] aspect-square flex flex-col items-center justify-start pt-8">
          <div class="w-20 h-20 rounded-full bg-white flex items-center justify-center mb-2">
            <img src={url('/images/icons/feature-gestion.svg')} alt="" class="w-10 h-10" />
          </div>
          <h3 class="text-3xl sm:text-4xl lg:text-[4rem] lg:leading-[5rem] text-gray-950 mb-5">Gestion Simplifiée</h3>
          <p class="text-gray-700 text-base lg:text-[1.1rem] lg:leading-7">
            Gérez facilement vos ingrédients, fournisseurs et calculs automatiques&nbsp;: tout est centralisé et actualisé en temps réel pour un pilotage sans stress.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comment ça marche ? -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Texte -->
        <div>
          <h2 class="text-4xl sm:text-5xl lg:text-6xl xl:text-[5.5rem] xl:leading-[5rem] text-gray-950">Comment ça marche&nbsp;?</h2>
          <p class="mt-6 text-xl sm:text-2xl lg:text-[1.875rem] lg:leading-9 font-medium text-gray-950">
            Optimisez vos coûts matière en 3 clics&nbsp;!
          </p>
          <div class="mt-12 space-y-10">
            <div class="flex items-center gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-black bg-white flex items-center justify-center p-1">
                <span class="font-heading text-2xl lg:text-[2.5rem] text-black leading-none">1</span>
              </div>
              <p class="text-lg sm:text-xl lg:text-2xl text-gray-950">Entrez vos fournisseurs &amp; produits</p>
            </div>
            <div class="flex items-center gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-black bg-white flex items-center justify-center p-1">
                <span class="font-heading text-2xl lg:text-[2.5rem] text-black leading-none">2</span>
              </div>
              <p class="text-lg sm:text-xl lg:text-2xl text-gray-950">Ajouter votre recette</p>
            </div>
            <div class="flex items-center gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-full border-2 border-black bg-white flex items-center justify-center p-1">
                <span class="font-heading text-2xl lg:text-[2.5rem] text-black leading-none">3</span>
              </div>
              <p class="text-lg sm:text-xl lg:text-2xl text-gray-950">Ajustez pour la rentabilité</p>
            </div>
          </div>
        </div>
        <!-- Illustration -->
        <div class="flex justify-center lg:justify-end">
          <img
            src={url('/images/app-screenshot.png')}
            alt="Capture d'écran de l'application Recèto — Bien plus qu'un food cost"
            class="w-full max-w-sm lg:max-w-md h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Chiffres clés — fond vert -->
  <section class="bg-[#5EE9B5] py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl xl:text-[5.5rem] xl:leading-[5rem] text-gray-950 text-center">Recèto en chiffres</h2>
      <div class="mt-14 grid grid-cols-1 sm:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center">
          <p class="font-heading text-5xl lg:text-7xl text-gray-950">900+</p>
          <p class="mt-3 text-lg lg:text-xl text-gray-800 font-medium">ingrédients référencés</p>
          <p class="mt-1 text-base text-gray-700">avec empreinte carbone intégrée</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-5xl lg:text-7xl text-gray-950">30s</p>
          <p class="mt-3 text-lg lg:text-xl text-gray-800 font-medium">pour créer une fiche technique</p>
          <p class="mt-1 text-base text-gray-700">coût matière et CO2 calculés en temps réel</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-5xl lg:text-7xl text-gray-950">100%</p>
          <p class="mt-3 text-lg lg:text-xl text-gray-800 font-medium">hébergé en France</p>
          <p class="mt-1 text-base text-gray-700">données sécurisées, conformes RGPD</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing — fond bleu -->
  <section class="relative bg-brand-500 py-20 lg:py-28 overflow-hidden">
    <img
      src={url('/images/wave-rainbow-arc.png')}
      alt=""
      class="absolute left-0 bottom-0 w-full h-auto object-cover pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6 lg:px-12">
      <!-- Sous-titre -->
      <p class="text-center text-xl sm:text-2xl lg:text-[1.875rem] lg:leading-9 font-medium text-white mb-10">
        Un forfait adapté à votre établissement, sans frais cachés.
      </p>
      <!-- Toggle Annuel / Mensuel -->
      <div class="flex flex-col items-center gap-4 mb-14">
        <div class="inline-flex items-center rounded-lg border border-white overflow-hidden p-1">
          <button
            id="btn-annuel-home"
            class="rounded-md px-5 py-2.5 text-base font-normal bg-white text-brand-500 transition-colors"
            data-period="annuel"
          >
            Annuel
          </button>
          <button
            id="btn-mensuel-home"
            class="rounded-md px-5 py-2.5 text-base font-normal text-white transition-colors"
            data-period="mensuel"
          >
            Mensuel
          </button>
        </div>
        <p class="text-base font-light text-white text-center">
          Économisez 2 mois avec le forfait annuel
        </p>
      </div>
      <!-- Cards -->
      <div class="flex flex-col md:flex-row gap-10 lg:gap-[77px] items-stretch justify-center">
        {plans.map((plan) => (
          <div class="bg-brand-500 border-2 border-white rounded-[10px] p-5 w-full max-w-[272px] mx-auto md:mx-0 flex items-center">
            <div class="flex flex-col gap-9 w-full h-full">
              <!-- Top content -->
              <div class="flex flex-col gap-10 flex-1">
                <!-- Header -->
                <div class="space-y-10">
                  <div class="space-y-3 text-gray-50">
                    <p class="font-heading text-4xl lg:text-[3rem] leading-[60px] tracking-[0.48px]">
                      {plan.name}
                    </p>
                    <p class="font-lexend font-light text-sm leading-[18px]">
                      {plan.description}
                    </p>
                  </div>

                  <!-- Price -->
                  <div class="space-y-2.5 text-gray-50">
                    {plan.price === null ? (
                      <>
                        <p class="font-lexend font-medium text-[2rem] leading-8">Gratuit</p>
                        {plan.subtitle && (
                          <p class="font-lexend font-light text-xs leading-4 text-gray-50">{plan.subtitle}</p>
                        )}
                      </>
                    ) : (
                      <>
                        {/* Annual pricing (visible by default) */}
                        <div class="price-annuel-home">
                          <div class="flex items-start gap-2.5">
                            <span class="relative font-lexend font-medium text-base text-brand-200 leading-8">
                              {plan.originalPrice}€/mois
                              <span class="absolute left-0 top-1/2 w-full h-px bg-brand-200 -rotate-[23deg]"></span>
                            </span>
                            <span class="font-lexend font-medium text-[2rem] leading-8 text-gray-50">
                              {plan.price}€{plan.period}
                            </span>
                          </div>
                          {plan.annualInfo && (
                            <div class="mt-2.5 font-lexend font-light text-xs leading-4 text-gray-50">
                              <p class="font-bold">{plan.annualInfo}</p>
                              <p>({plan.annualSaving})</p>
                            </div>
                          )}
                        </div>
                        {/* Monthly pricing (hidden by default) */}
                        <div class="price-mensuel-home hidden">
                          <span class="font-lexend font-medium text-[2rem] leading-8 text-gray-50">
                            {plan.originalPrice}€/mois
                          </span>
                        </div>
                      </>
                    )}
                  </div>
                </div>

                <!-- Features -->
                <div class="space-y-2">
                  <hr class="border-gray-50/30" />
                  <div class="space-y-2">
                    {plan.currentFeatures.slice(0, 4).map((feature) => (
                      <div class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 text-white" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M11.6667 3.5L5.25 9.91667L2.33333 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="font-lexend font-light text-sm leading-[14px] text-gray-50">{feature}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <!-- CTA -->
              <a
                href={plan.cta.href}
                class:list={[
                  "inline-flex items-center justify-center rounded-[5px] px-7 py-2.5 text-base font-normal font-lexend transition-colors w-full",
                  plan.price === null
                    ? "bg-gray-50 border border-brand-500 text-brand-600"
                    : "border-2 border-gray-50 text-gray-50 hover:bg-white/10"
                ]}
              >
                {plan.cta.label}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ils nous font confiance -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl xl:text-[5.5rem] xl:leading-[5rem] text-gray-950 text-center mb-16">Ils nous font confiance</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 items-center justify-items-center max-w-5xl mx-auto">
        <img src={url('/images/partners/talenz.png')} alt="Talenz" class="h-36 lg:h-44 w-auto object-contain" loading="lazy" />
        <img src={url('/images/partners/cci.png')} alt="CCI Vaucluse" class="h-36 lg:h-44 w-auto object-contain" loading="lazy" />
        <img src={url('/images/partners/grand-avignon.png')} alt="Grand Avignon" class="h-36 lg:h-44 w-auto object-contain" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 lg:py-24 bg-gray-50">
    <div class="mx-auto max-w-3xl px-6 lg:px-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl text-gray-950 text-center mb-12">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqItems.map((item, i) => (
          <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden" open={i === 0}>
            <summary class="flex cursor-pointer items-center justify-between p-5 font-medium text-gray-950 hover:bg-gray-50 transition-colors">
              {item.question}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-gray-600 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        }
      }))
    })} />
  </section>

  <script>
    const btnAnnuel = document.getElementById('btn-annuel-home');
    const btnMensuel = document.getElementById('btn-mensuel-home');
    const priceAnnuel = document.querySelectorAll('.price-annuel-home');
    const priceMensuel = document.querySelectorAll('.price-mensuel-home');

    function setPeriod(period: 'annuel' | 'mensuel') {
      const isAnnuel = period === 'annuel';
      const active = isAnnuel ? btnAnnuel! : btnMensuel!;
      const inactive = isAnnuel ? btnMensuel! : btnAnnuel!;
      active.classList.add('bg-white', 'text-brand-500');
      active.classList.remove('text-white');
      inactive.classList.remove('bg-white', 'text-brand-500');
      inactive.classList.add('text-white');
      priceAnnuel.forEach(el => el.classList.toggle('hidden', !isAnnuel));
      priceMensuel.forEach(el => el.classList.toggle('hidden', isAnnuel));
    }

    btnAnnuel?.addEventListener('click', () => setPeriod('annuel'));
    btnMensuel?.addEventListener('click', () => setPeriod('mensuel'));
  </script>
</BaseLayout>
