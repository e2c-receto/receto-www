---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Réserver une démo"
  description="Réservez une démonstration personnalisée de Recèto avec notre équipe. Découvrez comment maîtriser la rentabilité et l'empreinte carbone de vos recettes."
>
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Texte -->
        <div>
          <h1 class="text-4xl sm:text-5xl text-gray-950">
            Discutons de vos <span class="text-brand-500">besoins</span>
          </h1>
          <p class="mt-6 text-lg text-gray-600 leading-relaxed">
            Réservez un créneau de 30 minutes avec notre équipe.
            On vous montre Recèto en action sur vos propres recettes.
          </p>
          <div class="mt-8 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-brand-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <p class="text-gray-600">Démo personnalisée avec vos recettes et vos fournisseurs</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-brand-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <p class="text-gray-600">30 minutes, sans engagement, en visio ou sur place</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-brand-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <p class="text-gray-600">On répond à toutes vos questions sur le produit et les tarifs</p>
            </div>
          </div>

          <!-- Formulaire de contact -->
          <div class="mt-10 p-6 rounded-xl bg-gray-50 border border-gray-200">
            <p class="font-semibold text-gray-950 mb-3">Vous préférez nous écrire ?</p>
            <form action="https://formspree.io/f/mdawabeg" method="POST" class="space-y-3">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <input type="text" name="name" placeholder="Nom" required
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 outline-none" />
                <input type="email" name="email" placeholder="Email" required
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 outline-none" />
              </div>
              <input type="tel" name="phone" placeholder="Téléphone (optionnel)"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 outline-none" />
              <textarea name="message" rows="3" placeholder="Votre message" required
                class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:border-brand-500 focus:ring-1 focus:ring-brand-500 outline-none resize-none"></textarea>
              <button type="submit"
                class="w-full rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-600 transition-colors">
                Envoyer le message
              </button>
            </form>
            <p class="mt-3 text-xs text-gray-500 text-center">
              Ou directement : <a href="mailto:contact@receto.fr" class="text-brand-500 hover:underline">contact@receto.fr</a>
              · <a href="tel:+33667993446" class="text-brand-500 hover:underline">06 67 99 34 46</a>
            </p>
          </div>
        </div>

        <!-- Calendly embed -->
        <div class="rounded-2xl overflow-hidden min-h-[660px]">
          <div
            class="calendly-inline-widget"
            data-url="https://calendly.com/baptiste-c-eco2chef/30min?hide_gdpr_banner=1&primary_color=155dfc"
            style="min-width:320px;height:660px;"
          ></div>
          <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
