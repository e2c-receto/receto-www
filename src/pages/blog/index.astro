---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog"
  description="Conseils, astuces et actualités pour les restaurateurs. Rentabilité, gestion des coûts, empreinte carbone."
>
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h1 class="text-4xl sm:text-5xl text-gray-950">Blog</h1>
        <p class="mt-4 text-lg font-medium text-gray-950">
          Conseils, astuces et actualités pour les restaurateurs.
        </p>
        <p class="mt-4 text-base text-gray-600 leading-relaxed">
          Retrouvez nos articles pour mieux gérer votre restaurant : maîtriser vos coûts matière, réduire votre empreinte carbone et optimiser la rentabilité de vos recettes au quotidien.
        </p>
      </div>

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
              {post.data.image && (
                <img src={post.data.image} alt="" class="w-full aspect-video object-cover" />
              )}
              <div class="p-6">
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="inline-block text-xs font-medium text-brand-500 mb-2">{post.data.tags[0]}</span>
                )}
                <h2 class="text-lg font-semibold text-gray-950 group-hover:text-brand-500 transition-colors">
                  {post.data.title}
                </h2>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p>Les premiers articles arrivent bientôt.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
