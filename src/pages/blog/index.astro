---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog"
  description="Conseils, astuces et actualités pour les restaurateurs. Rentabilité, gestion des coûts, empreinte carbone."
>
  <!-- Hero -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-3xl mb-16">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-[8rem] leading-[0.95] text-gray-950">
          Blog
        </h1>
        <p class="mt-6 text-xl sm:text-2xl lg:text-[1.875rem] lg:leading-9 font-medium text-gray-950">
          Conseils, astuces et actualités pour les restaurateurs.
        </p>
        <p class="mt-4 text-lg lg:text-2xl text-gray-600 leading-relaxed">
          Retrouvez nos articles pour mieux gérer votre restaurant : maîtriser vos coûts matière, réduire votre empreinte carbone et optimiser la rentabilité de vos recettes au quotidien.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog cards grid -->
  <section class="pb-20 lg:pb-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {posts.map((post) => (
            <a
              href={url(`/blog/${post.slug}`)}
              class="group flex flex-col justify-between bg-gray-100 border-4 border-black rounded-[20px] p-5 max-w-[658px] hover:shadow-lg transition-shadow"
            >
              <div class="space-y-4">
                <p class="text-base text-gray-950">
                  {post.data.date.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                </p>
                <h3 class="text-3xl sm:text-4xl lg:text-[4rem] lg:leading-[5rem] text-gray-950 group-hover:text-brand-500 transition-colors">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="font-lexend font-light text-base leading-5 text-gray-950">
                    {post.data.description}
                  </p>
                )}
              </div>
              {post.data.image && (
                <div class="mt-4 h-[259px] overflow-hidden rounded-[10px]">
                  <img
                    src={url(post.data.image)}
                    alt=""
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p>Les premiers articles arrivent bientôt.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
