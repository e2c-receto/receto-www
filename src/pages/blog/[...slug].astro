---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image}
>
  <!-- Hero article -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <time class="text-base text-gray-500">{post.data.date.toLocaleDateString('fr-FR')}</time>
      <h1 class="mt-4 font-heading text-4xl sm:text-5xl lg:text-6xl leading-[0.95] text-gray-950">
        {post.data.title}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-3xl">{post.data.description}</p>
    </div>
  </section>

  <article class="pb-20 lg:pb-28">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-gray max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
