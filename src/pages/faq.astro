---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';

const faqCategories = [
  {
    title: "Général",
    items: [
      {
        question: "Qu'est-ce que Recèto ?",
        answer: "Recèto est une application logicielle en tant que service (SaaS) conçue spécifiquement pour les chefs cuisiniers. Elle permet de saisir les fiches techniques, calculer les coûts matières et l'empreinte carbone de chaque recette."
      },
      {
        question: "Quels bénéfices concrets apporte Recèto ?",
        answer: "Création d'un catalogue standardisé, optimisation des coûts matière (5 % en régime établi), connaissance de l'empreinte carbone et réduction de 15 % en moyenne, meilleur suivi des coûts d'achats."
      },
      {
        question: "Recèto, comment ça marche ?",
        answer: "Vous décrivez vos matières premières avec vos fournisseurs et coûts, vous décrivez vos recettes, Recèto calcule automatiquement le coût matière et la rentabilité. Vous pouvez ensuite modifier les ingrédients pour optimiser."
      },
      {
        question: "Recèto est-il adapté à tous types d'établissements ?",
        answer: "Oui, Recèto convient aux restaurants indépendants, chaînes, traiteurs et collectivités nécessitant de standardiser leurs recettes."
      },
      {
        question: "Comment puis-je accéder à Recèto ?",
        answer: "Via un navigateur web ou l'application mobile, depuis tout appareil disposant d'une connexion internet."
      },
      {
        question: "Recèto remplace-t-il mon logiciel de gestion ?",
        answer: "Non, c'est un outil de conception de recettes visant la rentabilité économique et la réduction d'empreinte carbone. Il est complémentaire de votre logiciel de caisse ou de gestion de stock."
      },
    ]
  },
  {
    title: "Recettes et produits",
    items: [
      {
        question: "Comment Recèto m'aide-t-il à calculer mes coûts ?",
        answer: "En créant une fiche recette, vous listez les ingrédients et le grammage. Recèto calcule automatiquement le coût matière exact par portion."
      },
      {
        question: "Qu'est-ce qu'une recette rentable ?",
        answer: "Une recette dont le ratio (Chiffre d'Affaires HT / Coût matières HT) est supérieur à 4, permettant d'équilibrer les comptes de l'établissement."
      },
      {
        question: "Qu'est-ce que le taux de rebut d'une recette ?",
        answer: "C'est le pourcentage de préparation non vendue ou ratée. Il se configure par recette pour ajuster les coûts matières au plus juste."
      },
      {
        question: "Quels sont les ingrédients possibles d'une recette ?",
        answer: "Un produit brut sélectionné dans votre liste, ou une recette réutilisable sélectionnée dans la liste des recettes (sous-recette)."
      },
      {
        question: "Comment créer ma liste de produits bruts ?",
        answer: "Vous pouvez importer depuis la base de données de référence Recèto ou créer manuellement vos produits avec les données de vos fournisseurs et leurs coûts."
      },
      {
        question: "Recèto permet-il de créer un produit sans renseigner l'empreinte carbone ?",
        answer: "Oui, mais le calcul d'empreinte carbone sera approximatif ou erroné pour les recettes concernées."
      },
      {
        question: "Quelle est la différence entre l'unité d'achat et l'unité d'utilisation ?",
        answer: "L'unité d'achat correspond à celle de votre fournisseur. L'unité d'utilisation permet les conversions automatiques en grammes pour les calculs de recettes."
      },
      {
        question: "Comment Recèto prend-il en compte l'évolution des coûts des produits bruts ?",
        answer: "Toute correction des coûts d'achat est propagée automatiquement et instantanément dans toutes les recettes concernées."
      },
      {
        question: "Qu'est-ce que la catégorie d'une recette ?",
        answer: "C'est une classification permettant de structurer votre portefeuille (préparations, accompagnements, vendues) avec des seuils de ratio et de rebut personnalisables."
      },
      {
        question: "Comment interpréter les couleurs et indicateurs de Recèto ?",
        answer: "La lettre A (vert) indique un ratio fort et une empreinte très faible. Les lettres C à E (rouge/mauve) signalent un ratio faible et une empreinte élevée."
      },
      {
        question: "À quoi sert de décider si une recette est vendue et/ou réutilisable ?",
        answer: "Les recettes vendues nécessitent un nombre de portions et un prix de vente. Les recettes réutilisables nécessitent une unité d'utilisation, car elles servent d'ingrédients dans d'autres recettes."
      },
      {
        question: "Recèto peut-il prendre en compte mes recettes existantes ?",
        answer: "Cette fonctionnalité sera disponible prochainement."
      },
      {
        question: "Est-ce que Recèto gère les allergènes et les valeurs nutritionnelles ?",
        answer: "Pas encore, cela fera l'objet d'évolutions spécifiques futures."
      },
      {
        question: "Puis-je partager mes recettes avec mon équipe ?",
        answer: "Cette fonctionnalité sera disponible prochainement."
      },
    ]
  },
  {
    title: "Abonnement et tarification",
    items: [
      {
        question: "Quel est le modèle de tarification de Recèto ?",
        answer: "Un système simple d'abonnement mensuel ou annuel. Consultez notre page Tarifs pour les détails."
      },
      {
        question: "Comment puis-je bénéficier des évolutions de Recèto ?",
        answer: "Les évolutions sont incluses selon votre niveau d'abonnement."
      },
      {
        question: "Proposez-vous un essai gratuit ?",
        answer: "Oui, une période d'essai gratuite de 14 jours sans engagement vous permet de tester toutes les fonctionnalités."
      },
      {
        question: "Puis-je annuler ou modifier mon abonnement à tout moment ?",
        answer: "Oui, l'annulation ou la modification est possible depuis votre tableau de bord. Elle prend effet à la fin de la période en cours."
      },
    ]
  },
  {
    title: "Sécurité et données",
    items: [
      {
        question: "Mes recettes sont-elles en sécurité ?",
        answer: "Oui. Nous utilisons un chiffrement de pointe (SSL/TLS), vos données sont hébergées sur des serveurs sécurisés conformes au RGPD, avec une sauvegarde quotidienne."
      },
      {
        question: "Que se passe-t-il si ma connexion internet est interrompue ?",
        answer: "Une connexion internet est indispensable pour l'utilisation complète de Recèto."
      },
      {
        question: "Comment puis-je récupérer mes données si je décide de partir ?",
        answer: "Vous pouvez exporter vos données en formats standard (CSV, PDF). Vos données vous appartiennent, conformément à notre clause de réversibilité."
      },
    ]
  },
  {
    title: "Empreinte carbone",
    items: [
      {
        question: "Qu'est-ce que l'empreinte carbone d'un plat ?",
        answer: "C'est la quantité totale de gaz à effet de serre émise durant le cycle de vie des ingrédients, exprimée en kg CO₂ équivalent."
      },
      {
        question: "Pourquoi évaluer l'empreinte carbone des plats ?",
        answer: "L'alimentation génère 25 % des émissions nationales de GES. La viande bovine représente 28 kg CO₂e/kg contre 0,5 pour les courgettes. Connaître ces données permet d'agir concrètement."
      },
      {
        question: "Quelle est la base méthodologique utilisée par Recèto ?",
        answer: "Une Analyse de Cycle de Vie multicritère suivant les normes ISO 14040 et ISO 14044."
      },
      {
        question: "Quelles bases de données sont utilisées ?",
        answer: "Agribalyse 3.2 (ADEME-INRAE), Open Food Facts, et l'IA à la marge pour compléter l'empreinte carbone moyenne."
      },
      {
        question: "Quelles sont les étapes prises en compte dans les calculs ?",
        answer: "La phase agricole, la transformation, la logistique, le stockage, la conservation et la préparation culinaire."
      },
      {
        question: "Que représente le contenu de l'assiette dans le bilan carbone d'un restaurant ?",
        answer: "En moyenne, 80 % de la quantité de CO₂e émise par l'établissement au global."
      },
      {
        question: "Que représente le transport dans l'empreinte carbone des aliments ?",
        answer: "Moins de 10 % de l'empreinte carbone en général. Exception pour les aliments importés par avion, dont l'impact est multiplié par 5 à 10."
      },
      {
        question: "Quelles sont les limites du modèle actuel ?",
        answer: "Le modèle ne prend pas encore en compte les émissions liées aux pratiques du personnel ni le déplacement de la clientèle."
      },
      {
        question: "Recèto est-il vérifié ou certifié ?",
        answer: "Notre méthodologie est conforme aux recommandations de l'ADEME et utilise la base Agribalyse avec une grille d'interprétation standardisée."
      },
    ]
  },
];

// Flatten for JSON-LD
const allItems = faqCategories.flatMap(c => c.items);
---

<BaseLayout
  title="FAQ"
  description="Questions fréquentes sur Recèto : fonctionnement, tarifs, empreinte carbone, sécurité des données et plus encore."
>
  <!-- Hero -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-4xl">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-[8rem] leading-[0.95] text-gray-950">
          FAQ
        </h1>
        <p class="mt-8 font-lexend font-medium text-xl sm:text-2xl lg:text-[30px] lg:leading-[36px] text-gray-950">
          Toutes les réponses à vos questions sur Recèto
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ par catégorie -->
  <section class="pb-20 lg:pb-28">
    <div class="mx-auto max-w-4xl px-6 lg:px-12 space-y-16">
      {faqCategories.map((category) => (
        <div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl text-gray-950 mb-8">{category.title}</h2>
          <div class="space-y-3">
            {category.items.map((item, i) => (
              <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden">
                <summary class="flex cursor-pointer items-center justify-between p-5 font-lexend font-medium text-gray-950 hover:bg-gray-50 transition-colors">
                  {item.question}
                  <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 font-lexend font-light text-gray-600 leading-relaxed">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-brand-500">
    <div class="mx-auto max-w-3xl px-6 lg:px-12 text-center">
      <p class="text-2xl sm:text-3xl lg:text-4xl text-white mb-4">Vous n'avez pas trouvé votre réponse&nbsp;?</p>
      <p class="font-lexend text-lg text-white/80 mb-8">Notre équipe est là pour vous aider.</p>
      <a
        href={url('/demo')}
        class="inline-flex items-center justify-center rounded-[10px] bg-white px-8 py-4 text-lg font-semibold text-brand-500 hover:bg-gray-100 transition-colors"
      >
        Contactez-nous
      </a>
    </div>
  </section>

  <!-- JSON-LD FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": allItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      }
    }))
  })} />
</BaseLayout>
