---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
import faqCategories from '../data/faq.json';

const allItems = faqCategories.flatMap(c => c.items);
---

<BaseLayout
  title="FAQ"
  description="Questions fréquentes sur Recèto : fonctionnement, tarifs, empreinte carbone, sécurité des données et plus encore."
>
  <!-- Hero -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-4xl">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-[8rem] leading-[0.95] text-gray-950">
          FAQ
        </h1>
        <p class="mt-8 font-lexend font-medium text-xl sm:text-2xl lg:text-[30px] lg:leading-[36px] text-gray-950">
          Toutes les réponses à vos questions sur Recèto
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ par catégorie -->
  <section class="pb-20 lg:pb-28">
    <div class="mx-auto max-w-4xl px-6 lg:px-12 space-y-16">
      {faqCategories.map((category) => (
        <div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl text-gray-950 mb-8">{category.title}</h2>
          <div class="space-y-3">
            {category.items.map((item, i) => (
              <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden">
                <summary class="flex cursor-pointer items-center justify-between p-5 font-lexend font-medium text-gray-950 hover:bg-gray-50 transition-colors">
                  {item.question}
                  <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </summary>
                <div class="px-5 pb-5 font-lexend font-light text-gray-600 leading-relaxed">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-brand-500">
    <div class="mx-auto max-w-3xl px-6 lg:px-12 text-center">
      <p class="text-2xl sm:text-3xl lg:text-4xl text-white mb-4">Vous n'avez pas trouvé votre réponse&nbsp;?</p>
      <p class="font-lexend text-lg text-white/80 mb-8">Notre équipe est là pour vous aider.</p>
      <a
        href={url('/demo')}
        class="inline-flex items-center justify-center rounded-[10px] bg-white px-8 py-4 text-lg font-semibold text-brand-500 hover:bg-gray-100 transition-colors"
      >
        Contactez-nous
      </a>
    </div>
  </section>

  <!-- JSON-LD FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": allItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      }
    }))
  })} />
</BaseLayout>
