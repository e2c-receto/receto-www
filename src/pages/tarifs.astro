---
import BaseLayout from '../layouts/BaseLayout.astro';
import { plans } from '../data/pricing';
import { url } from '../utils/url';
---

<BaseLayout
  title="Tarifs"
  description="Tarifs Recèto : un plan gratuit pour tester, des formules à partir de 39€/mois pour les restaurateurs. Sans engagement."
>
  <!-- Section 1 - Hero -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-4xl">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-[8rem] leading-[0.95] text-gray-950">
          Nos offres
        </h1>
        <p class="mt-8 font-lexend font-medium text-xl sm:text-2xl lg:text-[1.875rem] lg:leading-9 text-gray-950">
          Un forfait mensuel ou annuel
        </p>
        <div class="mt-8 space-y-4 font-lexend text-lg sm:text-xl lg:text-2xl leading-relaxed text-gray-950">
          <p>
            Profitez d'<strong>une offre unique</strong> et transparente <strong>pour les restaurateurs</strong> : Recèto vous propose un forfait mensuel ou annuel, sans frais cachés, adapté à la gestion et l'optimisation de vos recettes.
          </p>
          <p>
            Bénéficiez d'un <strong>accès complet</strong> à notre outil de pilotage, avec la possibilité de choisir la période qui convient à votre établissement pour augmenter votre marge et maîtriser votre impact environnemental.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2 - Pricing Cards -->
  <section class="relative bg-[#417cfd] py-20 lg:py-28 overflow-hidden">
    <img
      src={url('/images/wave-rainbow-arc.png')}
      alt=""
      class="absolute left-0 bottom-0 w-full h-auto object-cover pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6 lg:px-12">
      <!-- Toggle Annuel / Mensuel -->
      <div class="flex flex-col items-center gap-4 mb-16">
        <div class="inline-flex items-center rounded-lg border border-white overflow-hidden p-1">
          <button
            id="btn-annuel-tarifs"
            class="rounded-md px-5 py-2.5 text-base font-normal bg-white text-brand-500 transition-colors"
            data-period="annuel"
          >
            Annuel
          </button>
          <button
            id="btn-mensuel-tarifs"
            class="rounded-md px-5 py-2.5 text-base font-normal text-white transition-colors"
            data-period="mensuel"
          >
            Mensuel
          </button>
        </div>
        <p class="text-base font-light text-white text-center">
          Économisez 2 mois avec le forfait annuel
        </p>
      </div>

      <!-- Cards -->
      <div class="flex flex-col md:flex-row gap-10 lg:gap-[77px] items-stretch justify-center">
        {plans.map((plan) => (
          <div class="bg-brand-500 border-2 border-white rounded-[10px] p-5 w-full max-w-[272px] mx-auto md:mx-0 flex items-center">
            <div class="flex flex-col gap-9 w-full h-full">
              <!-- Top content -->
              <div class="flex flex-col gap-10 flex-1">
                <!-- Header -->
                <div class="space-y-10">
                  <div class="space-y-3 text-gray-50">
                    <p class="font-heading text-4xl lg:text-[3rem] leading-[60px] tracking-[0.48px]">
                      {plan.name}
                    </p>
                    <p class="font-lexend font-light text-sm leading-[18px]">
                      {plan.description}
                    </p>
                  </div>

                  <!-- Price -->
                  <div class="space-y-2.5 text-gray-50">
                    {plan.price === null ? (
                      <>
                        <p class="font-lexend font-medium text-[2rem] leading-8">Gratuit</p>
                        {plan.subtitle && (
                          <p class="font-lexend font-light text-xs leading-4 text-gray-50">{plan.subtitle}</p>
                        )}
                      </>
                    ) : (
                      <>
                        {/* Annual pricing (visible by default) */}
                        <div class="price-annuel">
                          <div class="flex items-start gap-2.5">
                            <span class="relative font-lexend font-medium text-base text-brand-200 leading-8">
                              {plan.originalPrice}€/mois
                              <span class="absolute left-0 top-1/2 w-full h-px bg-brand-200 -rotate-[23deg]"></span>
                            </span>
                            <span class="font-lexend font-medium text-[2rem] leading-8 text-gray-50">
                              {plan.price}€{plan.period}
                            </span>
                          </div>
                          {plan.annualInfo && (
                            <div class="mt-2.5 font-lexend font-light text-xs leading-4 text-gray-50">
                              <p class="font-bold">{plan.annualInfo}</p>
                              <p>({plan.annualSaving})</p>
                            </div>
                          )}
                        </div>
                        {/* Monthly pricing (hidden by default) */}
                        <div class="price-mensuel hidden">
                          <span class="font-lexend font-medium text-[2rem] leading-8 text-gray-50">
                            {plan.originalPrice}€/mois
                          </span>
                        </div>
                      </>
                    )}
                  </div>
                </div>

                <!-- Features -->
                <div class="space-y-2">
                  <hr class="border-gray-50/30" />
                  <div class="space-y-2">
                    {plan.currentFeatures.map((feature) => (
                      <div class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5 flex-shrink-0 text-white" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M11.6667 3.5L5.25 9.91667L2.33333 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span class="font-lexend font-light text-sm leading-[14px] text-gray-50">{feature}</span>
                      </div>
                    ))}
                  </div>

                  {plan.futureLabel && (
                    <>
                      <div class="inline-block bg-gray-950 rounded px-1.5 py-1.5">
                        <span class="font-lexend font-medium text-[8px] leading-[4px] text-orange-50">
                          {plan.futureLabel}
                        </span>
                      </div>
                      <div class="space-y-2">
                        {plan.futureFeatures.map((feature) => (
                          <div class="flex items-center gap-1">
                            <span class="font-lexend font-light text-sm leading-[14px] text-gray-50">{feature}</span>
                          </div>
                        ))}
                      </div>
                    </>
                  )}
                </div>
              </div>

              <!-- CTA -->
              <a
                href={plan.cta.href}
                class:list={[
                  "inline-flex items-center justify-center rounded-[5px] px-7 py-2.5 text-base font-normal font-lexend transition-colors w-full",
                  plan.price === null
                    ? "bg-gray-50 border border-brand-500 text-brand-600"
                    : "border-2 border-gray-50 text-gray-50 hover:bg-white/10"
                ]}
              >
                {plan.cta.label}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3 - Création base de données -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Texte -->
        <div class="lg:w-[40%]">
          <h2 class="text-4xl sm:text-5xl lg:text-6xl xl:text-[4rem] xl:leading-[4.5rem] text-gray-950">
            Création base de données
          </h2>
          <p class="mt-6 font-lexend font-medium text-xl sm:text-2xl lg:text-[30px] lg:leading-[36px] text-gray-950">
            On vous aide ! Concentrez-vous sur l'essentiel, nous nous occupons du reste
          </p>
          <div class="mt-6 flex items-center gap-6">
            <span class="font-lexend text-base text-gray-950">À partir de</span>
            <span class="font-lexend font-semibold text-5xl lg:text-[64px] lg:leading-[50px] text-gray-950">290<span class="text-2xl lg:text-[32px]">€</span></span>
          </div>
          <div class="mt-8 font-lexend text-lg sm:text-xl lg:text-2xl lg:leading-[30px] text-gray-950 space-y-4">
            <p>
              Simplifiez la création et la gestion de votre base de données, vos fournisseurs, vos produits et vos prix : avec Recèto, toutes vos informations sont centralisées au même endroit, toujours accessibles et à jour.
            </p>
            <p>
              Notre équipe vous accompagne pour une prise en main rapide et efficace, afin que vous puissiez consacrer plus de temps à l'innovation culinaire et à la satisfaction de vos clients.
            </p>
          </div>
          <div class="mt-10 flex justify-center lg:justify-start">
            <a
              href={url('/demo')}
              class="inline-flex items-center justify-center rounded-[5px] bg-brand-500 border border-gray-50 px-8 py-3 font-lexend text-base text-white hover:bg-brand-600 transition-colors"
            >
              Demander un devis
            </a>
          </div>
        </div>
        <!-- Mockup -->
        <div class="lg:w-[60%]">
          <img
            src={url('/images/mockup-desktop-produits.png')}
            alt="Interface Recèto — gestion des produits"
            class="w-full h-auto lg:scale-110 lg:origin-right"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4 - Bénéfices de Recèto -->
  <section class="bg-brand-500 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-4xl text-white">
        <h2 class="text-4xl sm:text-5xl lg:text-6xl">
          Bénéfices de Recèto
        </h2>
        <p class="mt-10 font-lexend font-medium text-lg sm:text-xl lg:text-[1.875rem] lg:leading-9">
          Notre service est créateur de valeur pour les restaurateurs, traiteurs et chefs. Optimisez vos achats, réduisez vos coûts matières et augmentez votre performance.
        </p>
        <p class="mt-6 font-lexend font-medium text-lg sm:text-xl lg:text-[1.875rem] lg:leading-9">
          <strong>1&nbsp;% d'optimisation des coûts matière, c'est 2&nbsp;000&nbsp;€ de rentabilité supplémentaire</strong> pour un restaurant avec 200&nbsp;000&nbsp;€ de chiffre d'affaires annuel.
        </p>
        <p class="mt-6 font-lexend font-medium text-lg sm:text-xl lg:text-[1.875rem] lg:leading-9">
          <strong>Recèto,</strong> c'est un outil puissant pour <strong>améliorer votre marge,</strong> piloter vos fiches techniques et engager votre démarche éco-responsable.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-3xl px-6 lg:px-12 text-center">
      <p class="text-2xl sm:text-3xl lg:text-4xl text-gray-950 mb-4">Prêt à optimiser vos recettes&nbsp;?</p>
      <p class="text-lg text-gray-600 mb-8">Réservez 30 minutes avec notre équipe pour découvrir Recèto sur vos propres recettes.</p>
      <a
        href={url('/demo')}
        class="inline-flex items-center justify-center rounded-[10px] bg-brand-500 px-8 py-4 text-lg font-semibold text-white hover:bg-brand-600 transition-colors"
      >
        Demander une démo
      </a>
    </div>
  </section>

  <script>
    const btnAnnuel = document.getElementById('btn-annuel-tarifs');
    const btnMensuel = document.getElementById('btn-mensuel-tarifs');
    const priceAnnuel = document.querySelectorAll('.price-annuel');
    const priceMensuel = document.querySelectorAll('.price-mensuel');

    function setPeriod(period: 'annuel' | 'mensuel') {
      const isAnnuel = period === 'annuel';
      // Toggle buttons
      const active = isAnnuel ? btnAnnuel! : btnMensuel!;
      const inactive = isAnnuel ? btnMensuel! : btnAnnuel!;
      active.classList.add('bg-white', 'text-brand-500');
      active.classList.remove('text-white');
      inactive.classList.remove('bg-white', 'text-brand-500');
      inactive.classList.add('text-white');
      // Toggle price blocks
      priceAnnuel.forEach(el => el.classList.toggle('hidden', !isAnnuel));
      priceMensuel.forEach(el => el.classList.toggle('hidden', isAnnuel));
    }

    btnAnnuel?.addEventListener('click', () => setPeriod('annuel'));
    btnMensuel?.addEventListener('click', () => setPeriod('mensuel'));
  </script>
</BaseLayout>
