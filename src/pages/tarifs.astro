---
import BaseLayout from '../layouts/BaseLayout.astro';
import { plans } from '../data/pricing';
import { url } from '../utils/url';
---

<BaseLayout
  title="Tarifs"
  description="Tarifs Recèto : un plan gratuit pour tester, des formules à partir de 39€/mois pour les restaurateurs. Sans engagement."
>
  <!-- Section 1 - Hero -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-3xl">
        <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl xl:text-[6.5rem] leading-[0.95] text-gray-950">
          Nos offres
        </h1>
        <p class="mt-6 text-xl sm:text-2xl lg:text-[1.875rem] lg:leading-9 font-medium text-gray-950">
          Un forfait mensuel ou annuel
        </p>
        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          Profitez d'<strong class="text-gray-950">une offre unique</strong> et transparente <strong class="text-gray-950">pour les restaurateurs</strong> : Recèto vous propose un forfait mensuel ou annuel, sans frais cachés, adapté à la gestion et l'optimisation de vos recettes.
        </p>
        <p class="mt-4 text-lg text-gray-600 leading-relaxed">
          Bénéficiez d'un <strong class="text-gray-950">accès complet</strong> à notre outil de pilotage, avec la possibilité de choisir la période qui convient à votre établissement pour augmenter votre marge et maîtriser votre impact environnemental.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2 - Pricing -->
  <section class="relative bg-brand-500 py-20 lg:py-28 overflow-hidden">
    <img
      src={url('/images/wave-blue.png')}
      alt=""
      class="absolute right-0 top-0 h-full w-auto object-cover pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6 lg:px-12">
      <!-- Toggle Annuel / Mensuel -->
      <div class="text-center mb-4">
        <div class="inline-flex items-center rounded-lg border border-white overflow-hidden p-1">
          <button
            id="btn-annuel-tarifs"
            class="rounded-md px-5 py-2.5 text-base font-normal bg-white text-brand-500 transition-colors"
            data-period="annuel"
          >
            Annuel
          </button>
          <button
            id="btn-mensuel-tarifs"
            class="rounded-md px-5 py-2.5 text-base font-normal text-white transition-colors"
            data-period="mensuel"
          >
            Mensuel
          </button>
        </div>
      </div>
      <p class="text-center text-base font-light text-white mb-14">
        Économisez 2 mois avec le forfait annuel
      </p>
      <!-- Cards -->
      <div class="flex flex-col md:flex-row gap-10 lg:gap-[77px] items-center justify-center">
        {plans.map((plan) => (
          <div class:list={[
            "bg-white rounded-[10px] border-4 w-full max-w-[312px] h-auto min-h-[580px] flex items-center px-5 py-8",
            plan.featured ? "border-brand-500" : "border-gray-950"
          ]}>
            <div class="flex flex-col gap-20 items-center w-full">
              <div class="w-full space-y-10">
                <!-- Header -->
                <div class:list={["space-y-6", plan.featured ? "text-brand-500" : "text-gray-950"]}>
                  <p class="text-base font-normal uppercase">{plan.name}</p>
                  <div class="flex items-center gap-1">
                    <span class="font-heading text-5xl lg:text-[4rem] lg:leading-[5rem]">
                      {plan.price === null ? 'Gratuit' : `${plan.price}\u20AC`}
                    </span>
                    {plan.period && <span class="text-base font-medium">{plan.period}</span>}
                  </div>
                  <p class="text-base font-light text-center">{plan.description}</p>
                </div>
                <!-- Features -->
                <div class="space-y-6">
                  <hr class:list={[plan.featured ? "border-brand-500" : "border-gray-950"]} />
                  <div class:list={["space-y-2 text-base font-light", plan.featured ? "text-brand-500" : "text-gray-950"]}>
                    {plan.features.slice(0, 4).map((feature) => (
                      <p>{feature.label}{feature.value ? ` (${feature.value})` : ''}</p>
                    ))}
                  </div>
                  <hr class:list={[plan.featured ? "border-brand-500" : "border-gray-950"]} />
                </div>
              </div>
              <!-- CTA -->
              <a
                href={plan.cta.href}
                class:list={[
                  "inline-flex items-center justify-center rounded-md px-5 py-2.5 text-base font-light transition-colors",
                  plan.featured
                    ? "bg-brand-500 border border-brand-500 text-white hover:bg-brand-600"
                    : plan.price === 69
                      ? "bg-black border border-gray-950 text-white hover:bg-gray-800"
                      : "border border-gray-950 text-gray-950 hover:bg-gray-100"
                ]}
              >
                {plan.cta.label}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3 - Création base de données -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <h2 class="font-heading text-4xl sm:text-5xl lg:text-6xl text-gray-950 text-center">
        Création base de données
      </h2>
      <p class="mt-8 text-lg text-gray-600 leading-relaxed max-w-xl">
        Avec ces futures mises à jour, bénéficiez d'une solution globale pour faire progresser votre entreprise dans une démarche responsable et profitable.
      </p>
    </div>
  </section>

  <!-- Section 4 - Bénéfices de Recèto -->
  <section class="bg-brand-500 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <div class="max-w-3xl text-white">
        <h2 class="font-heading text-4xl sm:text-5xl lg:text-6xl">
          Bénéfices de Recèto
        </h2>
        <p class="mt-6 text-lg leading-relaxed opacity-90">
          Notre service est créateur de valeur pour les restaurateurs, traiteurs et chefs. Optimisez vos achats, réduisez vos coûts matières et augmentez votre performance.
        </p>
        <p class="mt-6 text-lg leading-relaxed opacity-90">
          <strong class="text-white">1&nbsp;% d'optimisation des coûts matière, c'est 2&nbsp;000&nbsp;€ de rentabilité supplémentaire</strong> pour un restaurant avec 200&nbsp;000&nbsp;€ de chiffre d'affaires annuel.
        </p>
        <p class="mt-6 text-lg leading-relaxed opacity-90">
          <strong class="text-white">Recèto,</strong> c'est un outil puissant pour <strong class="text-white">améliorer votre marge,</strong> piloter vos fiches techniques et engager votre démarche éco-responsable.
        </p>
      </div>
    </div>
  </section>

  <script>
    const btnAnnuel = document.getElementById('btn-annuel-tarifs');
    const btnMensuel = document.getElementById('btn-mensuel-tarifs');

    function setActive(active: HTMLElement, inactive: HTMLElement) {
      active.classList.add('bg-white', 'text-brand-500');
      active.classList.remove('text-white');
      inactive.classList.remove('bg-white', 'text-brand-500');
      inactive.classList.add('text-white');
    }

    btnAnnuel?.addEventListener('click', () => setActive(btnAnnuel, btnMensuel!));
    btnMensuel?.addEventListener('click', () => setActive(btnMensuel, btnAnnuel!));
  </script>
</BaseLayout>
